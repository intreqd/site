---
interface Props {
  align?: "left" | "center";
  eyebrow?: string;
  class?: string;
}

const { align = "left", eyebrow, class: className } = Astro.props;
---

<div
  class:list={[
    "space-y-3",
    align === "center" && "mx-auto max-w-3xl text-center",
    align === "left" && "max-w-3xl",
    className,
  ]}
>
  {eyebrow && <p class="badge badge-outline">{eyebrow}</p>}
  <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
    <slot name="title">Title</slot>
  </h1>
  <p class="text-base text-base-content/70 sm:text-lg">
    <slot name="desc">Some description goes here</slot>
  </p>
</div>
