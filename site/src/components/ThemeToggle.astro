---
/**
 * ThemeToggle — switches between DaisyUI's light and dark theme.
 *
 * How it works:
 *   1. Layout.astro has an inline <script> in <head> that reads localStorage
 *      and sets data-theme on <html> before first paint — no flash.
 *   2. This component reads that attribute and toggles it on click,
 *      then persists the choice to localStorage.
 *
 * To add more themes (e.g. "cupcake", "forest"), replace the binary toggle
 * with a <select> or a theme picker and update the DaisyUI theme list in
 * theme.css / astro.config.mjs.
 */
---

<button
  x-data="{
    theme: document.documentElement.getAttribute('data-theme') || 'light',
    toggle() {
      this.theme = this.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', this.theme);
      localStorage.setItem('theme', this.theme);
    }
  }"
  @click="toggle()"
  :aria-label="theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'"
  class="btn btn-ghost btn-square"
>
  <!-- Sun — shown when dark mode is active -->
  <svg x-show="theme === 'dark'" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
  </svg>
  <!-- Moon — shown when light mode is active -->
  <svg x-show="theme === 'light'" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
  </svg>
</button>
