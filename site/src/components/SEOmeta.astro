---
import { SEO } from "astro-seo";
import { siteConfig } from "site-config";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const { title = siteConfig.title, description, image, canonical } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const resolvedImage = image ?? new URL("/opengraph.jpg", Astro.site).toString();
---

<SEO
  title={title}
  description={description ?? siteConfig.description}
  canonical={canonicalURL}
  twitter={{
    creator: siteConfig.seo.twitterHandle,
    site: siteConfig.seo.twitterSite,
    card: "summary_large_image",
  }}
  openGraph={{
    basic: {
      url: canonicalURL,
      type: "website",
      title: title,
      image: resolvedImage,
    },
    image: {
      alt: title,
    },
  }}
/>
