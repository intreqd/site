---
import { getCollection } from "astro:content";

const posts = await getCollection('blog', ({ data }) => !data.draft);
const postData = posts.map(p => ({
  title: p.data.title,
  url: `/blog/${p.id}`
}));
---

<div id="blog-ticker" class="mt-4 rounded-box border border-base-300 bg-base-200/50 backdrop-blur-sm overflow-hidden flex flex-col">
  <!-- Header / Divider -->
  <div class="flex items-center justify-between gap-3 border-b border-base-300 px-4 py-2.5 bg-base-300/30">
    <div class="flex items-center gap-2">
      <span class="flex h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
      <span class="text-[10px] uppercase tracking-widest font-bold text-base-content/50">Latest Insights</span>
    </div>
    <a href="/blog" class="btn btn-xs btn-ghost border border-base-content/10 text-[9px] h-5 min-h-0 px-2 font-mono text-base-content/40 hover:text-primary hover:border-primary/30 transition-all">BLOG</a>
  </div>
  
  <!-- Content -->
  <div class="px-4 py-3.5">
    <div id="ticker-container" class="relative overflow-hidden min-h-[1.5rem] flex items-center">
      <div id="ticker-content" class="w-full transition-all duration-1000 opacity-0 translate-y-1">
        <a href="#" id="ticker-link" class="text-sm font-medium text-base-content/70 hover:text-primary transition-colors truncate block">
          Loading...
        </a>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ postData }}>
  function initTicker() {
    const content = document.getElementById('ticker-content');
    const link = document.getElementById('ticker-link');
    
    if (!content || !link || !postData || postData.length === 0) return;

    let currentIdx = -1;
    
    function updateTicker() {
      // Fade out and move down slightly
      content.classList.add('opacity-0', 'translate-y-1');
      
      setTimeout(() => {
        let nextIdx;
        if (postData.length > 1) {
          do {
            nextIdx = Math.floor(Math.random() * postData.length);
          } while (nextIdx === currentIdx);
        } else {
          nextIdx = 0;
        }
        currentIdx = nextIdx;
        
        const post = postData[currentIdx];
        link.textContent = post.title;
        link.href = post.url;
        
        // Fade in and move to position
        content.classList.remove('opacity-0', 'translate-y-1');
      }, 1000);
    }
    
    // Initial run
    updateTicker();
    
    // Set interval for cycling
    const interval = setInterval(updateTicker, 6000);

    // Cleanup
    document.addEventListener('astro:before-preparation', () => clearInterval(interval), { once: true });
  }

  initTicker();
  document.addEventListener('astro:page-load', initTicker);
</script>
