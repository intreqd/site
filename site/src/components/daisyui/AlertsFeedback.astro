---
import ShowcaseSection from "@components/daisyui/ShowcaseSection.astro";
---

<ShowcaseSection
  id="alerts-feedback"
  title="Alerts and feedback states"
  description="DaisyUI alerts cover status messaging without extra wrappers. Use vertical-on-mobile alert layouts when actions and descriptions need to stay readable on narrow screens."
  components={["alert", "btn", "badge", "mockup-code"]}
>
  <div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,22rem)]">
    <div class="space-y-4">
      <div role="alert" class="alert alert-info alert-soft alert-vertical sm:alert-horizontal">
        <span class="badge badge-info badge-soft">Info</span>
        <div>
          <h3 class="font-bold">New message</h3>
          <div class="text-sm">You have one unread update in the release checklist.</div>
        </div>
        <button class="btn btn-sm">Open</button>
      </div>

      <div role="alert" class="alert alert-success alert-outline">
        <span>Deployment completed successfully.</span>
      </div>

      <div role="alert" class="alert alert-warning alert-soft">
        <span>Replace placeholder legal text before going live.</span>
      </div>
    </div>

    <div class="mockup-code w-full">
      <pre data-prefix="$"><code>{`<div role="alert" class="alert alert-info alert-vertical sm:alert-horizontal">`}</code></pre>
      <pre data-prefix="$"><code>{`  <button class="btn btn-sm">Open</button>`}</code></pre>
      <pre data-prefix="$"><code>{`</div>`}</code></pre>
    </div>
  </div>
</ShowcaseSection>
