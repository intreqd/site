---
interface Props {
  id: string;
  title: string;
  description: string;
  components: string[];
}

const { id, title, description, components } = Astro.props;
---

<section id={id} class="scroll-mt-24 space-y-6">
  <div class="space-y-3">
    <h2 class="text-3xl font-bold tracking-tight">{title}</h2>
    <p class="max-w-3xl text-base text-base-content/70 sm:text-lg">{description}</p>
    <div class="flex flex-wrap gap-2">
      {components.map((name) => (
        <span class="badge badge-soft badge-primary">{name}</span>
      ))}
    </div>
  </div>
  <slot />
</section>
