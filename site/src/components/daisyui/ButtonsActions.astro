---
import ShowcaseSection from "@components/daisyui/ShowcaseSection.astro";
---

<ShowcaseSection
  id="buttons-actions"
  title="Buttons and grouped actions"
  description="Use DaisyUI buttons for the main action language of the starter. `join` is especially useful when you want grouped actions without building custom button bars."
  components={["btn", "join", "badge", "mockup-code"]}
>
  <div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,22rem)]">
    <div class="card border border-base-300 bg-base-100 shadow-sm">
      <div class="card-body gap-6">
        <div class="space-y-3">
          <h3 class="card-title">Call-to-action group</h3>
          <p class="text-sm text-base-content/70">
            Good default for hero sections, feature pages, or article headers where one action leads and the rest support it.
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <button class="btn btn-primary">
            Start project
            <span class="badge badge-sm badge-primary-content">New</span>
          </button>
          <button class="btn btn-outline">Read docs</button>
          <button class="btn btn-ghost">View demo</button>
        </div>

        <div class="join">
          <button class="btn join-item btn-sm">Preview</button>
          <button class="btn join-item btn-sm">Duplicate</button>
          <button class="btn join-item btn-sm btn-error">Archive</button>
        </div>
      </div>
    </div>

    <div class="mockup-code w-full">
      <pre data-prefix="$"><code>{`<button class="btn btn-primary">Start project</button>`}</code></pre>
      <pre data-prefix="$"><code>{`<div class="join"><button class="btn join-item">…</button></div>`}</code></pre>
    </div>
  </div>
</ShowcaseSection>
