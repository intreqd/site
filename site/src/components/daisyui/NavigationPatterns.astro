---
import ShowcaseSection from "@components/daisyui/ShowcaseSection.astro";
---

<ShowcaseSection
  id="navigation-patterns"
  title="Navigation patterns"
  description="Use DaisyUI navigation primitives when you need secondary structure inside a page or dashboard area. Menu, tabs, and breadcrumbs cover most starter-level navigation needs without custom components."
  components={["menu", "tabs", "tab", "breadcrumbs"]}
>
  <div class="grid gap-6 xl:grid-cols-[18rem_minmax(0,1fr)]">
    <aside class="card border border-base-300 bg-base-100 shadow-sm">
      <div class="card-body">
        <h3 class="card-title">Sidebar menu</h3>
        <ul class="menu rounded-box bg-base-200">
          <li><a class="menu-active">Overview</a></li>
          <li><a>Content</a></li>
          <li><a>SEO</a></li>
          <li>
            <span class="menu-title">Publishing</span>
            <ul>
              <li><a>Drafts</a></li>
              <li><a>Scheduled</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </aside>

    <div class="space-y-4">
      <div class="breadcrumbs text-sm">
        <ul>
          <li><a>Dashboard</a></li>
          <li><a>Content</a></li>
          <li>Overview</li>
        </ul>
      </div>

      <div role="tablist" class="tabs tabs-box">
        <a role="tab" class="tab tab-active">Overview</a>
        <a role="tab" class="tab">Checklist</a>
        <a role="tab" class="tab">Notes</a>
      </div>

      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-3">
          <h3 class="card-title">Good default for content dashboards</h3>
          <p class="text-sm text-base-content/70">
            Combine a `menu` for persistent structure with `tabs` for local switching inside a section.
          </p>
        </div>
      </div>
    </div>
  </div>
</ShowcaseSection>
