---
const technologies = [
  { id: "kubernetes", label: "Kubernetes" },
  { id: "databricks", label: "Databricks" },
  { id: "helm", label: "Helm" },
  { id: "iris", label: "InterSystems IRIS" },
  { id: "healthShare", label: "HealthShare" },
  { id: "healthCareApi", label: "Healthcare API" },
  { id: "googleCloud", label: "Google Cloud" },
  { id: "ebpf", label: "eBPF" },
  { id: "cilium", label: "Cilium", isColor: true, url: "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/webp/cilium.webp" },
  { id: "prometheus", label: "Prometheus", isColor: true, url: "https://raw.githubusercontent.com/cncf/artwork/main/projects/prometheus/icon/color/prometheus-icon-color.svg" },
  { id: "spectroCloud", label: "Spectro Cloud", isColor: true, url: "https://cdn.prod.website-files.com/64105dfa8da6a9f617932c6c/67af0b614d589896c673443b_spectro-cloud-favicon%20(1).png" }
];
---

<div class="relative overflow-x-hidden py-8">
  <div
    class="pointer-events-none absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-base-100 to-transparent z-20"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-base-100 to-transparent z-20"
  >
  </div>

  <div class="flex animate-scroll hover:animate-paused gap-12 md:gap-20 w-max">
    {
      [...technologies, ...technologies, ...technologies].map((tech) => (
        <div class="flex items-center gap-2 group transition-all duration-300">
          <img
            src={tech.url || `/svg/${tech.id}.svg`}
            alt={tech.label}
            class:list={[
              "h-7 w-auto object-contain transition-transform group-hover:scale-110",
              tech.isColor ? "opacity-100" : "opacity-60 dark:invert"
            ]}
            width="30"
            height="30"
            loading="lazy"
          />
          <span class="text-lg font-medium text-base-content/70">
            {tech.label}
          </span>
        </div>
      ))
    }
  </div>
</div>

<style is:global>
  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .animate-scroll {
    animation: scroll 60s linear infinite;
  }

  @media (min-width: 768px) {
    .animate-scroll {
      animation-duration: 50s;
    }
  }
</style>
