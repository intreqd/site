---
import AlertsFeedback from "@components/daisyui/AlertsFeedback.astro";
import ButtonsActions from "@components/daisyui/ButtonsActions.astro";
import CardsStats from "@components/daisyui/CardsStats.astro";
import FormPatterns from "@components/daisyui/FormPatterns.astro";
import NavigationPatterns from "@components/daisyui/NavigationPatterns.astro";
import Container from "@components/elements/Container.astro";
import Sectionhead from "@components/elements/Sectionhead.astro";
import Layout from "@layouts/Layout.astro";

const sections = [
  {
    id: "buttons-actions",
    title: "Buttons and grouped actions",
    description: "Primary calls to action, secondary actions, and grouped button bars.",
  },
  {
    id: "alerts-feedback",
    title: "Alerts and feedback states",
    description: "Status messages with responsive action layouts and semantic emphasis.",
  },
  {
    id: "cards-stats",
    title: "Cards and stats",
    description: "Feature summaries, launch checklists, and compact metrics blocks.",
  },
  {
    id: "navigation-patterns",
    title: "Navigation patterns",
    description: "Menus, tabs, and breadcrumbs for secondary navigation inside pages.",
  },
  {
    id: "form-patterns",
    title: "Form and input patterns",
    description: "Fieldsets, inputs, selects, textareas, and small action groups.",
  },
];
---

<Layout
  title="DaisyUI reference"
  description="Starter-grade DaisyUI reference page with reusable component patterns."
>
  <Container class="py-12 sm:py-16 lg:py-24">
    <Sectionhead eyebrow="Reference">
      <Fragment slot="title">DaisyUI starter patterns developers can actually reuse.</Fragment>
      <Fragment slot="desc">
        This page is not a component gallery. It is a small set of starter-grade patterns built from DaisyUI and Tailwind primitives that developers can copy, adapt, and remix inside real Astro projects.
      </Fragment>
    </Sectionhead>

    <section class="mt-10 grid gap-6 xl:grid-cols-[minmax(0,1fr)_20rem]">
      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <h2 class="card-title">How to use this page</h2>
          <ul class="list-disc space-y-2 pl-5 text-sm text-base-content/75 sm:text-base">
            <li>Start from the section closest to your use case.</li>
            <li>Copy the markup from the page source, then simplify it for your project.</li>
            <li>Prefer DaisyUI classes first, Tailwind layout utilities second, and custom CSS last.</li>
          </ul>
        </div>
      </div>

      <aside class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <h2 class="card-title">Component index</h2>
          <dl class="space-y-4 text-sm">
            {sections.map((section) => (
              <div class="space-y-1">
                <dt>
                  <a class="link link-hover font-semibold" href={`#${section.id}`}>{section.title}</a>
                </dt>
                <dd class="text-base-content/70">{section.description}</dd>
              </div>
            ))}
          </dl>
        </div>
      </aside>
    </section>

    <div class="mt-14 space-y-14">
      <ButtonsActions />
      <AlertsFeedback />
      <CardsStats />
      <NavigationPatterns />
      <FormPatterns />
    </div>
  </Container>
</Layout>
