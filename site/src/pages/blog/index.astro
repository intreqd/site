---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Container from '@components/elements/Container.astro';
import Layout from '@layouts/Layout.astro';
import Sectionhead from '@components/elements/Sectionhead.astro';

type Post = CollectionEntry<'blog'>;

// Fetch all non-draft posts, newest first
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a: Post, b: Post) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog" description="All posts">
  <Container class="py-12 sm:py-16 lg:py-24">
    <Sectionhead eyebrow="Content">
      <Fragment slot="title">Blog</Fragment>
      <Fragment slot="desc">All posts, newest first.</Fragment>
    </Sectionhead>

    <section class="mt-10 max-w-3xl">
      {posts.length === 0 && (
        <div class="alert alert-info">
          <span>No posts yet. Add a Markdown file to <code>src/content/blog/</code>.</span>
        </div>
      )}

      <ul class="flex flex-col gap-6">
        {posts.map((post: Post) => (
          <li>
            <a href={`/blog/${post.id}`} class="card border border-base-300 bg-base-100 transition-shadow hover:shadow-md">
              <div class="card-body gap-3">
                <h2 class="card-title">{post.data.title}</h2>
                <p class="text-sm text-base-content/70">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </p>
                <p>{post.data.description}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </Container>
</Layout>
