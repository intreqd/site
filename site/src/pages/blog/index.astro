---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Container from '@components/elements/Container.astro';
import Layout from '@layouts/Layout.astro';
import Sectionhead from '@components/elements/Sectionhead.astro';

type Post = CollectionEntry<'blog'>;

// Fetch all non-draft posts, newest first
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a: Post, b: Post) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog" description="All posts">
  <Container class="pt-6 sm:pt-8 lg:pt-12 pb-12 sm:pb-16 lg:pb-24">
    <Sectionhead eyebrow="Content">
      <Fragment slot="title">Blog</Fragment>
      <Fragment slot="desc">These are the views of my employer.</Fragment>
    </Sectionhead>

    <section class="mt-10">
      {posts.length === 0 && (
        <div class="alert alert-info">
          <span>No posts yet. Add a Markdown file to <code>src/content/blog/</code>.</span>
        </div>
      )}
      
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {posts.map((post: Post) => (
          <li class="h-full">
            <a href={`/blog/${post.id}`} class="card border border-base-300 bg-base-100 transition-all hover:shadow-xl hover:-translate-y-1 h-full overflow-hidden group">
              <figure class="aspect-[12/2] w-full overflow-hidden bg-base-200">
                {post.data.heroImage ? (
                  <img 
                    src={post.data.heroImage} 
                    alt={post.data.title} 
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" 
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center text-base-content/20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
              </figure>
              <div class="card-body gap-3">
                <div class="flex flex-wrap items-center gap-2">
                  <time class="text-sm font-medium text-base-content/60" datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {post.data.categories && post.data.categories.length > 0 && (
                    <div class="flex flex-wrap gap-1">
                      {post.data.categories.map((category) => (
                        <span class="badge badge-primary badge-sm badge-outline">{category}</span>
                      ))}
                    </div>
                  )}
                </div>
                <h2 class="card-title text-2xl group-hover:text-primary transition-colors">{post.data.title}</h2>
                <p class="text-base-content/70 line-clamp-3">{post.data.description}</p>
                <div class="card-actions justify-end mt-auto">
                  <span class="text-sm font-bold text-primary group-hover:underline">Read more →</span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </Container>
</Layout>
