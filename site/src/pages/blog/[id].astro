---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Container from '@components/elements/Container.astro';
import Layout from '@layouts/Layout.astro';

// getStaticPaths() tells Astro which URLs to generate at build time.
// One page is built per non-draft blog post.
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post: CollectionEntry<'blog'>) => ({ params: { id: post.id }, props: { post } }));
}

// Explicit props interface — CollectionEntry<'blog'> is the fully-typed
// entry shape generated from the schema in src/content.config.ts.
interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <Container class="py-12 sm:py-16 lg:py-24">
    <article class="max-w-3xl">
      <header class="space-y-4">
        <a href="/blog" class="link link-hover text-sm text-base-content/60">← All posts</a>

      <!--
        heroImage is optional. Astro's <Image /> component optimizes the image
        at build time: converts to WebP/AVIF, generates srcset, prevents CLS.
        For remote URLs, add the hostname to `image.domains` in astro.config.mjs.
        For local files, import them in frontmatter or use the image() schema helper.
        Docs: https://docs.astro.build/en/guides/images/
      -->
      {post.data.heroImage && (
        <Image
          src={post.data.heroImage}
          alt={post.data.title}
          width={1200}
          height={630}
          class="mt-2 w-full rounded-box object-cover"
        />
      )}

        <div class="space-y-2">
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">{post.data.title}</h1>
          <p class="text-sm text-base-content/60">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {post.data.updatedDate && (
              <span>
                · Updated <time datetime={post.data.updatedDate.toISOString()}>
                  {post.data.updatedDate.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </span>
            )}
          </p>
        </div>
      </header>

    <!--
      daisyUI recommends using Tailwind utilities for layout and the Typography
      plugin for rich text. `prose` gives Markdown content predictable defaults
      without maintaining a custom article stylesheet in the starter.
    -->
      <div class="prose prose-neutral mt-10 max-w-none prose-a:link prose-img:rounded-box">
        <Content />
      </div>
    </article>
  </Container>
</Layout>
