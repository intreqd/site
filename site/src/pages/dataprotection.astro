---
import Container from "@components/elements/Container.astro";
import Sectionhead from "@components/elements/Sectionhead.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout title="Data Protection">
  <Container class="py-12 sm:py-16 lg:py-24">
    <Sectionhead eyebrow="Legal">
      <Fragment slot="title">Data protection</Fragment>
      <Fragment slot="desc">Use this page as the starting point for your privacy notice.</Fragment>
    </Sectionhead>

    <section class="mt-10 max-w-3xl">
      <div class="alert">
        <span>
          This starter includes the route so you can add your actual privacy content before going live.
        </span>
      </div>
    </section>
  </Container>
</Layout>
