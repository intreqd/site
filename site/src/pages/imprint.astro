---
import Container from "@components/elements/Container.astro";
import Sectionhead from "@components/elements/Sectionhead.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout title="Imprint">
  <Container class="py-12 sm:py-16 lg:py-24">
    <Sectionhead eyebrow="Legal">
      <Fragment slot="title">Imprint</Fragment>
      <Fragment slot="desc">Integration Required business details.</Fragment>
    </Sectionhead>

    <section class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <h2 class="card-title">Service provider information</h2>
          <div class="space-y-3 text-base text-base-content/80">
            <p><strong>Integration Required</strong></p>
            <p>Ron Sweeney</p>
            <p>Michigan<br />USA</p>
            <p>
              <strong>Tel:</strong>1-616-465-4705<br />
              <strong>Email:</strong> <a class="link link-hover" href="mailto:hi@integrationrequired.com">hi@integrationrequired.com</a>
            </p>
          </div>
        </div>
      </div>

      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <h2 class="card-title">Legal Business Entity</h2>
          <div class="space-y-3 text-base text-base-content/80">
            <p><strong>Integration Required, LLC</strong></p>
            <p>A Michigan Limited Liability Company</p>
            <p>LLC ID: <a href="https://mibusinessregistry.lara.state.mi.us/search/business" target="_blank" rel="noopener noreferrer" class="link link-primary link-hover">801654297</a></p>
          </div>
        </div>
      </div>

      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <h2 class="card-title">Insurance Information</h2>
          <div class="space-y-3 text-base text-base-content/80">
            <p><strong>Hiscox Insurance Company Inc.</strong></p>
            <p>Professional Liability<br />General Liability</p>
          </div>
        </div>
      </div>
    </section>
  </Container>
</Layout>
