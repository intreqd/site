---
import Container from "@components/elements/Container.astro";
import Layout from "@layouts/Layout.astro";
import { siteConfig } from "site-config";
import LogoWall from "@components/logoWall.astro";

const quickstart = `pnpm create astro@latest --template ${siteConfig.githubRepo}`;
const quickstartId = "quickstart-command";

// Keep page content data-driven so the homepage stays easy to scan and edit.
const featureCards = [
  {
    title: "DIMSE Cloud",
    description: "Multi Regional DICOM Service Class Provider, and Routing at Scale",
    items: ["IKO Powered Ingestion", "Google Cloud Healthcare API/DICOM Studio", "Cilium Powered CNI","Multi-Region Architecture"],
    badges: ["Google Cloud","InterSystems IKO"],
    buttons: [
      { text: "View Stack", url: "/daisyui", primary: true },
      { text: "Whitepaper", url: "https://docs.astro.build", primary: false }
    ]
  },
  {
    title: "lifestage.health",
    description: "Transforming high-frequency data from devices like WHOOP into clinical-grade evidence.",
    items: ["WHOOP Data Ingestion", "Multiple CDM Setup - Big Query/IRIS","OHDSI Ecosystem Implementation","Small Study Deployed for Global Collaboration"],
    badges: ["OHDSI", "InterSystems OMOP"],
    buttons: [
      { text: "Join the Journey", url: "https://lifestage.health", primary: true },
      { text: "Whitepaper", url: "/imprint", primary: false }
    ]
  },
  {
    title: "PID^TOO||",
    description: "FHIR® has an identify problem, this a battle tested solution.",
    items: ["Machine Learning Powered Detection", "Simplistic Matching & Scoring", "FHIR® Resource Driven Remediation", "Merge Strategies"],
    badges: ["FHIR®", "Google Cloud", "Zingg"],
    buttons: [
      { text: "Resolve Identities", url: "https://www.pidtoo.com", primary: true },
      { text: "Whitepaper", url: "#", primary: false }
    ]
  }
];

const interopTraits = [
  {
    logo: "/fhir.png",
    logoPos: "left",
    textAlign: "right",
    text: "HL7 FHIR implementation and healthcare data standards orchestration."
  },
  {
    logo: "/svg/oHDSI.svg",
    logoPos: "right",
    textAlign: "left",
    text: "OHDSI/OMOP common data model mapping and population health analytics."
  }
];

const starterTraits = [
  {
    logo: "/isc.png",
    logoPos: "left",
    textAlign: "right",
    text: '<a href="https://www.credly.com/users/sween" target="_blank" rel="noopener noreferrer" class="hover:underline text-primary transition-colors">Certified</a> and battle tested on InterSystems technologies, preferred weapon of mass solution and <a href="https://community.intersystems.com/user/sween" target="_blank" rel="noopener noreferrer" class="hover:underline text-primary transition-colors">developer community expert</a>.'
  },
  {
    logo: "https://raw.githubusercontent.com/cncf/artwork/main/other/kubestronaut/stacked/color/kubestronaut-stacked-color.svg",
    logoPos: "left",
    textAlign: "left",
    text: 'CNCF Kubestronaut <a href="https://www.credly.com/users/sween" target="_blank" rel="noopener noreferrer" class="hover:underline text-primary transition-colors">certified</a> with deep cloud-native architecture expertise, I deploy here first.'
  },
  {
    logo: "/svg/googleCloud.svg",
    logoPos: "right",
    textAlign: "left",
    text: '<a href="https://www.credly.com/users/sween" target="_blank" rel="noopener noreferrer" class="hover:underline text-primary transition-colors">Certified</a> and steward of production workloads and public Cloud of choice.  <a href="https://developers.google.com/program/gear/" target="_blank" rel="noopener noreferrer" class="hover:underline text-primary transition-colors">GEAR</a> and <a href="https://me.developers.google.com/u/ronsweeney" target="_blank" rel="noopener noreferrer" class="hover:underline text-primary transition-colors">g.developer</a> decorated.'
  }
];
---

<Layout
  title="Integration Required"
  description=""
>
  <Container class="pt-6 sm:pt-8 lg:pt-12 pb-3 sm:pb-4 lg:pb-6">
    <!--
      Mobile-first structure:
      1. Start with a single-column stack that reads well on narrow screens.
      2. Introduce multi-column layouts only from `lg:` upward.
    -->
    <section class="space-y-8 lg:grid lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,24rem)] lg:gap-10 lg:space-y-0">
      <div class="flex flex-col gap-6">
        <p class="badge badge-outline">Independent Contractor</p>

        <div class="space-y-4">
          <h1 class="max-w-3xl text-2xl font-bold tracking-tight sm:text-3xl">
            Named Technical Interoperability Engineer
          </h1>
          <p class="max-w-2xl text-base text-base-content/70 sm:text-lg">
Accelerate your workload, develop your Managed Service or strategic initiative with a short or long-term contract. Build secure, reliable, and performant workloads, healthcare interoperability, and advanced analytics at impossible deployment speeds.
          </p>

        </div>

        <div class="mt-auto space-y-4">
          <div class="grid gap-4 sm:grid-cols-2">
            {interopTraits.map((item) => (
              <div class="flex items-center gap-4 rounded-box border border-base-300 bg-base-100 px-5 py-4 shadow-sm">
                {item.logoPos === "left" && (
                  <img src={item.logo} alt="" class="h-10 w-10 shrink-0 object-contain dark:invert" />
                )}
                <p 
                  class:list={[
                    "flex-1 text-sm font-medium text-base-content/80 leading-relaxed",
                    item.textAlign === "right" && "text-right",
                    item.textAlign === "left" && "text-left"
                  ]}
                  set:html={item.text}
                />
                {item.logoPos === "right" && (
                  <img src={item.logo} alt="" class="h-10 w-10 shrink-0 object-contain dark:invert" />
                )}
              </div>
            ))}
          </div>

          <div class="grid gap-4 sm:grid-cols-3">
            {starterTraits.map((item) => (
              <div class="flex items-center gap-4 rounded-box border border-base-300 bg-base-100 px-5 py-4 shadow-sm">
                {item.logoPos === "left" && (
                  <img src={item.logo} alt="" class="h-10 w-10 shrink-0 object-contain dark:invert" />
                )}
                <p 
                  class:list={[
                    "flex-1 text-sm font-medium text-base-content/80 leading-relaxed",
                    item.textAlign === "right" && "text-right",
                    item.textAlign === "left" && "text-left"
                  ]}
                  set:html={item.text}
                />
                {item.logoPos === "right" && (
                  <img src={item.logo} alt="" class="h-10 w-10 shrink-0 object-contain dark:invert" />
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

      <aside class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
                    <div class="mt-2 space-y-3">
            <div class="hover-gallery rounded-box w-full aspect-4/3 overflow-hidden [--items:4]">
              <img src="ron.png" alt="Abstract 1" />
              <img src="ron2.png" alt="Abstract 2" />
              <img src="ron3.png" alt="Abstract 3" />
            </div>
          </div>
          <div class="rounded-box border border-base-300 bg-base-200">
            <div class="flex items-center justify-between gap-3 border-b border-base-300 px-4 py-3">
              <div class="flex items-center gap-2 text-xs uppercase tracking-wide text-base-content/60">
                <span class="h-2.5 w-2.5 rounded-full bg-success"></span>
                <span>Command</span>
              </div>
              <button
                type="button"
                class="btn btn-xs btn-ghost"
                data-copy-button
                data-copy-target={quickstartId}
              >
                Copy
              </button>
            </div>
            <pre class="overflow-x-auto px-4 py-4 text-sm leading-6"><code id={quickstartId}>{quickstart}</code></pre>
          </div>


        </div>
      </aside>
    </section>

    <LogoWall />

    <!-- Secondary information becomes a grid of 3 cards styled like the checklist. -->
    <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featureCards.map((card) => (
        <div 
          class:list={[
            "card card-compact relative overflow-hidden border border-base-300 shadow-sm transition-all duration-300 hover:shadow-md",
            card.title === "DIMSE Cloud" ? "bg-black text-white" : (card.title === "PID^TOO||" ? "text-white" : "bg-base-100")
          ]}
          style={card.title === "PID^TOO||" ? "background-color: #111D30" : (card.title === "lifestage.health" ? "background-color: #C8D5B9" : "")}
        >
          <div class="card-body gap-5 relative z-10">
            <div class="space-y-3">
              <div class="flex items-center justify-between gap-3">
                <h2 class:list={["card-title text-base font-bold", card.title === "lifestage.health" && "text-black"]}>{card.title}</h2>
                <div class="flex flex-wrap justify-end gap-1.5">
                  {card.badges.map((badge) => (
                    <span class:list={[
                      "badge badge-sm font-medium bg-transparent px-2.5 py-3 whitespace-nowrap",
                      card.title === "lifestage.health" ? "border-black text-black" : "border-white/50 text-white"
                    ]}>
                      {badge}
                    </span>
                  ))}
                </div>
              </div>
              <p class:list={[
                "text-sm", 
                (card.title === "DIMSE Cloud" || card.title === "PID^TOO||") ? "text-white/70" : (card.title === "lifestage.health" ? "text-black/70" : "text-base-content/70")
              ]}>
                {card.description}
              </p>
            </div>
            
            <ul class:list={[
              "list-disc space-y-2 pl-5 text-sm", 
              (card.title === "DIMSE Cloud" || card.title === "PID^TOO||") ? "text-white/80" : (card.title === "lifestage.health" ? "text-black/80" : "text-base-content/80")
            ]}>
              {card.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>

            <div class="card-actions justify-start mt-auto">
              {card.buttons.map((btn) => (
                <a 
                  href={btn.url} 
                  class:list={[
                    "btn btn-sm",
                    btn.primary ? (
                      card.title === "PID^TOO||" ? "text-white border-0" : 
                      (card.title === "lifestage.health" ? "text-black border-0" : "btn-primary")
                    ) : (
                      (card.title === "DIMSE Cloud" || card.title === "PID^TOO||") ? "btn-outline text-white hover:bg-white hover:text-black" : 
                      (card.title === "lifestage.health" ? "btn-outline border-black text-black hover:bg-black hover:text-white" : "btn-ghost")
                    )
                  ]}
                  style={
                    btn.primary ? (
                      card.title === "PID^TOO||" ? "background-color: #08AA6E" : 
                      (card.title === "lifestage.health" ? "background-color: #EDF6F5" : "")
                    ) : ""
                  }
                >
                  {btn.text}
                </a>
              ))}
            </div>
          </div>
          <img src="https://placehold.co/100x300" alt="" class="absolute bottom-0 right-0 h-32 w-auto opacity-10 pointer-events-none" />
        </div>
      ))}
    </section>
  </Container>
</Layout>

<script>
  function initCopyButtons() {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-button]').forEach((button) => {
      if (button.dataset.copyReady === 'true') return;
      button.dataset.copyReady = 'true';

      button.addEventListener('click', async () => {
        const targetId = button.getAttribute('data-copy-target');
        const source = targetId ? document.getElementById(targetId) : null;
        if (!source) return;

        const originalLabel = button.textContent ?? 'Copy';

        try {
          await navigator.clipboard.writeText(source.textContent ?? '');
          button.textContent = 'Copied';
        } catch {
          button.textContent = 'Failed';
        }

        window.setTimeout(() => {
          button.textContent = originalLabel;
        }, 1200);
      });
    });
  }

  // Re-run after Astro view transitions so the button works on client navigation too.
  document.addEventListener('astro:page-load', initCopyButtons);
</script>
